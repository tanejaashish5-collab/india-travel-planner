{
  "expo": {
    "name": "NakshIQ",
    "slug": "nakshiq",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nakshiq",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#161614"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nakshiq.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Show your distance from destinations and nearby places"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#161614"
      },
      "package": "com.nakshiq.app",
      "edgeToEdgeEnabled": true,
      "permissions": ["ACCESS_FINE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "SUPABASE_URL": "https://dudzsdzfvikjjhurxrgc.supabase.co",
      "SUPABASE_ANON_KEY": "placeholder"
    }
  }
}
