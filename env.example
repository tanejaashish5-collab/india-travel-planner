# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key-here

# Claude API (server-side only — never expose to client)
ANTHROPIC_API_KEY=

# Ably (SOS real-time)
ABLY_API_KEY=
NEXT_PUBLIC_ABLY_KEY=

# MSG91 (SMS for SOS)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Mapbox (mobile maps)
MAPBOX_ACCESS_TOKEN=

# Cloudflare R2 (video + image storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
NEXT_PUBLIC_VIDEO_BASE_URL=
# R2 public URL for the nakshiq-images bucket (e.g. https://pub-xxx.r2.dev
# or a custom domain). Falls back to site-local /images/ when unset.
NEXT_PUBLIC_IMAGE_BASE_URL=

# Resend (newsletter — The Window)
RESEND_API_KEY=
# Secret guarding /api/newsletter/send + the /[locale]/admin/newsletter UI.
# Use a long random string; set the same value in Vercel.
NEWSLETTER_SEND_SECRET=
